{
  "name": "giwa-village",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "playtest": "node scripts/launch-test.mjs",
    "showcase": "node scripts/launch-test.mjs --showcase",
    "test": "node scripts/test-logic.mjs",
    "test:local": "node scripts/test-local.mjs",
    "test:chain": "node scripts/test-chain.mjs",
    "smoke": "node scripts/sync-smoke.mjs",
    "gift": "node scripts/gift-smoke.mjs",
    "bots": "node scripts/bots.mjs",
    "stall-smoke": "node scripts/stall-smoke.mjs",
    "deploy-market": "node scripts/deploy-market.mjs",
    "market-smoke": "node scripts/market-smoke.mjs",
    "wallets": "node scripts/gen-wallets.mjs",
    "bridge": "node scripts/bridge-deposit.mjs",
    "faucet": "node scripts/faucet-check.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "solc": "^0.8.36"
  },
  "//anvil": "로컬 무가스 테스트(npm run test:local)용 anvil은 일부러 의존성에 넣지 않는다. Windows에서 postinstall이 깨지고, 배포 CI에는 불필요하며, optional로 두면 --omit=optional을 쓸 수밖에 없는데 그러면 rolldown 네이티브 바인딩까지 빠져 빌드가 깨진다. 설치: npm i @foundry-rs/anvil --ignore-scripts --no-save",
  "allowScripts": {
    "esbuild@0.28.1": true,
    "msgpackr-extract": false
  }
}
